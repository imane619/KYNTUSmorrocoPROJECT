{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "employee-route": {
        "ClusterId": "employee-cluster",
        "Match": { "Path": "/api/employees/{**catch-all}" }
      },
      "planning-route": {
        "ClusterId": "planning-cluster",
        "Match": { "Path": "/api/planning/{**catch-all}" }
      },
      "absence-route": {
        "ClusterId": "absence-cluster",
        "Match": { "Path": "/api/absences/{**catch-all}" }
      },
      "analytics-route": {
        "ClusterId": "analytics-cluster",
        "Match": { "Path": "/api/analytics/{**catch-all}" }
      },
      "reporting-route": {
        "ClusterId": "reporting-cluster",
        "Match": { "Path": "/api/reporting/{**catch-all}" }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/notifications/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": { "destination1": { "Address": "http://localhost:5001" } }
      },
      "employee-cluster": {
        "Destinations": { "destination1": { "Address": "http://localhost:5002" } }
      },
      "planning-cluster": {
        "Destinations": { "destination1": { "Address": "http://localhost:5003" } }
      },
      "absence-cluster": {
        "Destinations": { "destination1": { "Address": "http://localhost:5004" } }
      },
      "analytics-cluster": {
        "Destinations": { "destination1": { "Address": "http://localhost:5005" } }
      },
      "reporting-cluster": {
        "Destinations": { "destination1": { "Address": "http://localhost:5006" } }
      },
      "notification-cluster": {
        "Destinations": { "destination1": { "Address": "http://localhost:5007" } }
      }
    }
  }
}
